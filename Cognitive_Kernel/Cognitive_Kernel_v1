# LAYER 3: ASTROCYTIC REGULATOR (Metaplasticity Gate)
# ═════════════════════════════════════════════════════════════════════════════

class AstrocyticRegulator:
    """
    Simplified AstrocyticRegulator: monitors activity and gates learning.
    
    Real version: tripartite synapse with glutamate/calcium chemistry.
    Here: simplified threshold-based gate.
    """
    
    def __init__(self, num_neurons: int = 1024):
        self.num_neurons = num_neurons
        self.glutamate_level = 0.0
        self.calcium_level = 0.0
        self.plasticity_gate = 0.0
        self.decay_rate = 0.95
    
    def forward(self, neural_activity: float) -> float:
        """
        Compute plasticity gate based on neural activity.
        
        Returns: 0.0 (locked) to 1.0 (learning open)
        """
        # Glutamate accumulates with activity
        self.glutamate_level = (
            self.decay_rate * self.glutamate_level +
            (1.0 - self.decay_rate) * neural_activity
        )
        
        # Calcium driven by glutamate (threshold nonlinearity)
        self.calcium_level = math.tanh(5.0 * self.glutamate_level)
        
        # Gate: open if calcium > threshold
        threshold = 0.4
        if self.calcium_level > threshold:
            self.plasticity_gate = 1.0
        else:
            self.plasticity_gate = 0.0
        
        return self.plasticity_gate
    
    def get_state(self) -> Dict[str, float]:
        """Serialize astrocyte state."""
        return {
            "glutamate": self.glutamate_level,
            "calcium": self.calcium_level,
            "plasticity_gate": self.plasticity_gate,
        }


