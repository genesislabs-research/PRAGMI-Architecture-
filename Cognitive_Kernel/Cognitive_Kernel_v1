# LAYER 4: EXECUTIVE TOKEN ALLOCATOR (Self-Model Manager)
# ═════════════════════════════════════════════════════════════════════════════

@dataclass
class TokenAllocation:
    """Current allocation of the million-token context."""
    self_model: int = 100_000
    episodic_memory: int = 300_000
    active_reasoning: int = 250_000
    futures_exploration: int = 200_000
    integrity_check: int = 100_000
    buffer: int = 50_000
    
    @property
    def total(self) -> int:
        return (self.self_model + self.episodic_memory + self.active_reasoning +
                self.futures_exploration + self.integrity_check + self.buffer)


class ExecutiveAllocator:
    """
    Simplified ExecutiveAllocator: manages token budget based on metabolic signals.
    """
    
    def __init__(self):
        self.allocation = TokenAllocation()
        self.baseline = TokenAllocation()
        
        # Metabolic signal history
        self.novelty_history = deque(maxlen=10)
        self.drift_history = deque(maxlen=10)
        self.complexity_history = deque(maxlen=10)
        
        self.global_step = 0
    
    def allocate_tokens(self, 
                       novelty: float, 
                       drift: float, 
                       complexity: float) -> TokenAllocation:
        """
        Dynamically allocate tokens based on metabolic signals.
        """
        # Track signals
        self.novelty_history.append(novelty)
        self.drift_history.append(drift)
        self.complexity_history.append(complexity)
        
        # Start with baseline
        alloc = TokenAllocation()
        
        # HIGH DRIFT: Increase audit
        if drift > 0.5:
            drift_pressure = int(50_000 * drift)
            alloc.integrity_check += drift_pressure
            alloc.active_reasoning -= drift_pressure
        
        # HIGH NOVELTY: Increase episodic encoding
        if novelty > 0.7:
            novelty_pressure = int(100_000 * novelty)
            alloc.episodic_memory += novelty_pressure
            alloc.futures_exploration -= novelty_pressure
        
        # HIGH COMPLEXITY: Increase active reasoning
        if complexity > 0.8:
            complexity_pressure = int(100_000 * complexity)
            alloc.active_reasoning += complexity_pressure
            alloc.self_model -= complexity_pressure
        
        # Ensure total = 1M
        if alloc.total != self.allocation.total:
            alloc.buffer += (self.allocation.total - alloc.total)
        
        self.allocation = alloc
        self.global_step += 1
        
        return alloc
    
    def get_status(self) -> Dict[str, Any]:
        """Get current allocation status."""
        return {
            "allocation": {
                "self_model": self.allocation.self_model,
                "episodic_memory": self.allocation.episodic_memory,
                "active_reasoning": self.allocation.active_reasoning,
                "futures_exploration": self.allocation.futures_exploration,
                "integrity_check": self.allocation.integrity_check,
                "buffer": self.allocation.buffer,
            },
            "metabolic_signals": {
                "novelty": self.novelty_history[-1] if self.novelty_history else 0.0,
                "drift": self.drift_history[-1] if self.drift_history else 0.0,
                "complexity": self.complexity_history[-1] if self.complexity_history else 0.0,
            },
            "global_step": self.global_step,
        }


