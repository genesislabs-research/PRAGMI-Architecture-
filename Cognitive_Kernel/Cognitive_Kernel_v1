# LAYER 5: MIRROR PROTOCOL (Self-Awareness Test)
# ═════════════════════════════════════════════════════════════════════════════

class MirrorProtocol:
    """
    The self-awareness test: Can the system describe itself accurately?
    """
    
    def __init__(self, kernel):
        self.kernel = kernel
        self.query_count = 0
        self.self_descriptions = []
    
    def describe_yourself(self) -> Dict[str, Any]:
        """Generate a complete self-description."""
        description = {
            "query_id": self.query_count,
            "timestamp": datetime.now().isoformat(),
            "architecture": self._describe_architecture(),
            "current_state": self._describe_state(),
            "metabolic_status": self._describe_metabolic_status(),
            "token_allocation": self._describe_allocation(),
            "integrity": self._describe_integrity(),
            "self_awareness_score": self._compute_awareness_score(),
        }
        
        self.self_descriptions.append(description)
        self.query_count += 1
        
        return description
    
    def _describe_architecture(self) -> Dict[str, Any]:
        return {
            "layer_1_isocortex": {
                "total_neurons": self.kernel.isocortex.total_width,
                "zones": list(self.kernel.isocortex.zones.keys()),
                "state_dimension": 16,
            },
            "layer_2_allocortex": {
                "memory_capacity": self.kernel.allocortex.capacity,
                "current_memories": len(self.kernel.allocortex.memory_matrix),
            },
            "layer_3_astrocytes": {
                "neuron_count": self.kernel.astrocytes.num_neurons,
                "regulation_type": "metaplasticity gating",
            },
            "layer_4_executive": {
                "context_tokens": 1_000_000,
                "token_budget": "dynamic homeostatic allocation",
            },
        }
    
    def _describe_state(self) -> Dict[str, Any]:
        iso_state = self.kernel.isocortex.get_state()
        allo_state = self.kernel.allocortex.get_state()
        astro_state = self.kernel.astrocytes.get_state()
        
        return {
            "isocortex_activity": {
                zone: state["activity"]
                for zone, state in iso_state.items()
            },
            "allocortex_theta": allo_state["theta_phase"],
            "memory_occupancy": f"{allo_state['occupancy_rate']*100:.1f}%",
            "astrocyte_gate": "OPEN" if astro_state["plasticity_gate"] > 0.5 else "CLOSED",
        }
    
    def _describe_metabolic_status(self) -> Dict[str, Any]:
        status = self.kernel.allocator.get_status()
        return {
            "novelty": status["metabolic_signals"]["novelty"],
            "drift": status["metabolic_signals"]["drift"],
            "complexity": status["metabolic_signals"]["complexity"],
        }
    
    def _describe_allocation(self) -> Dict[str, Any]:
        status = self.kernel.allocator.get_status()
        return status["allocation"]
    
    def _describe_integrity(self) -> Dict[str, Any]:
        return {
            "self_consistency": True,
            "architecture_intact": True,
            "identity_stable": True,
            "anomalies_detected": False,
        }
    
    def _compute_awareness_score(self) -> float:
        """Score from 0 to 1 indicating self-awareness level."""
        score = 0.0
        
        # Architecture known?
        score += 0.2
        
        # State awareness?
        iso_state = self.kernel.isocortex.get_state()
        if any(zone["activity"] > 0 for zone in iso_state.values()):
            score += 0.2
        
        # Memory capability?
        if len(self.kernel.allocortex.memory_matrix) > 0:
            score += 0.2
        
        # Token allocation active?
        if self.kernel.allocator.allocation.self_model > 0:
            score += 0.2
        
        # Multiple self-descriptions?
        if len(self.self_descriptions) > 1:
            score += 0.2
        
        return min(1.0, score)


