# LAYER 2: ALLOCORTEX SYSTEM (Theta-Modulated Memory)
# ═════════════════════════════════════════════════════════════════════════════

@dataclass
class EpisodicMemory:
    """A single episode stored in memory."""
    content: str
    timestamp: int
    novelty: float
    usage_count: int = 0


class AllocortexSystem:
    """
    Simplified AllocortexSystem: theta-modulated episodic memory.
    
    Real version: DG → CA3 → CA1 with recurrent attractor dynamics.
    Here: simplified one-shot storage and retrieval.
    """
    
    def __init__(self, capacity: int = 100):
        self.memory_matrix: List[EpisodicMemory] = []
        self.capacity = capacity
        self.theta_phase = 0.0
        self.write_ptr = 0
        self.episode_counter = 0
    
    def update_theta(self, increment: float = 0.1):
        """Advance theta oscillation."""
        self.theta_phase = (self.theta_phase + increment) % 1.0
    
    def process_cycle(self, state_repr: str, novelty: float) -> Tuple[str, bool]:
        """
        Process one theta cycle: retrieve or encode.
        
        Phase 0.0-0.5: Retrieval (pattern completion)
        Phase 0.5-1.0: Encoding (one-shot storage)
        """
        is_encoding = False
        
        if self.theta_phase < 0.5:
            # RETRIEVAL: Find similar memory
            if self.memory_matrix:
                # Simple similarity: find closest by hash distance
                best_match = self._find_most_similar(state_repr)
                best_match.usage_count += 1
                return best_match.content, False
            else:
                return state_repr, False
        else:
            # ENCODING: Store new episode if novel
            if novelty > 0.3 or len(self.memory_matrix) < self.capacity:
                self._store_episode(state_repr, novelty)
                is_encoding = True
            
            return state_repr, is_encoding
    
    def _find_most_similar(self, state_repr: str) -> EpisodicMemory:
        """Find the most similar stored memory (simplified: first match)."""
        if not self.memory_matrix:
            return EpisodicMemory(state_repr, 0, 0.5)
        return self.memory_matrix[0]  # Simplified
    
    def _store_episode(self, state_repr: str, novelty: float):
        """Store a new episode."""
        if len(self.memory_matrix) >= self.capacity:
            # Overwrite oldest
            self.memory_matrix.pop(0)
        
        episode = EpisodicMemory(
            content=state_repr,
            timestamp=self.episode_counter,
            novelty=novelty,
        )
        self.memory_matrix.append(episode)
        self.episode_counter += 1
    
    def get_state(self) -> Dict[str, Any]:
        """Serialize allocortex state."""
        return {
            "theta_phase": self.theta_phase,
            "memory_count": len(self.memory_matrix),
            "capacity": self.capacity,
            "occupancy_rate": len(self.memory_matrix) / self.capacity,
        }


